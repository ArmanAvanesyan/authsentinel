# AuthSentinel Docker Compose – copy to .env and set values
# Required for authsentinel-agent (mock IdP for E2E)
# - OIDC_ISSUER is the issuer URL used by the agent for discovery + token validation.
# - OIDC_REDIRECT_URI is the redirect URI the browser follows back to the agent.
OIDC_ISSUER=http://mockidp:8082
OIDC_REDIRECT_URI=http://localhost:8080/callback
OIDC_CLIENT_ID=mock-client
OIDC_CLIENT_SECRET=mock-secret
SESSION_COOKIE_SIGNING_SECRET=0123456789abcdef0123456789abcdef
APP_BASE_URL=http://localhost:8080

# Optional: config file path (agent or proxy)
# CONFIG_PATH=configs/agent.dev.yaml

# Optional: admin endpoint guard (agent and proxy)
# ADMIN_SECRET=your-admin-secret
