# AuthSentinel Docker Compose – copy to .env and set values
# Required for authsentinel-agent
OIDC_ISSUER=https://your-oidc-provider/
OIDC_REDIRECT_URI=https://portal.example.com/oauth/callback
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
SESSION_COOKIE_SIGNING_SECRET=your-32-byte-secret-minimum
APP_BASE_URL=https://portal.example.com

# Optional: config file path (agent or proxy)
# CONFIG_PATH=configs/agent.dev.yaml

# Optional: admin endpoint guard (agent and proxy)
# ADMIN_SECRET=your-admin-secret
